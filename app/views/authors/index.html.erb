<h1>作者列表</h1>

<%= search_form_for @q, url: authors_path, method: :get, local: true do |f| %>
  <div>
    <%= f.label :name_cont, '搜索作者' %>
    <%= f.search_field :name_cont, placeholder: '请输入作者姓名' %>
  </div>

  <div>
    <%= f.label :age_gteq, '最小年龄' %>
    <%= f.number_field :age_gteq, min: 0, max: 120, placeholder: '0' %>
  </div>

  <div>
    <%= f.label :age_lteq, '最大年龄' %>
    <%= f.number_field :age_lteq, min: 0, max: 120, placeholder: '120' %>
  </div>

  <div>
    <%= f.label :gender_eq, '性别' %>
    <%= f.select :gender_eq, [['男', '男'], ['女', '女']], include_blank: "全部" %>
  </div>

  <div>
    <%= f.submit "搜索" %>
  </div>
<% end %>


<% if @authors.any? %>
  <table style="border-collapse: collapse; width: 50%; font-size: 12px; margin-left: 0;">
    <tr>
      <th style="border: 1px solid #000; padding: 5px;"><%= sort_link(@q, :name, "作者姓名") %></th>
      <th style="border: 1px solid #000; padding: 5px;"><%= sort_link(@q, :gender, "性别") %></th>
      <th style="border: 1px solid #000; padding: 5px;"><%= sort_link(@q, :age, "年龄") %></th>
      <th style="border: 1px solid #000; padding: 5px;">描述</th>
      <th style="border: 1px solid #000; padding: 5px;">身份证号</th>
      <th style="border: 1px solid #000; padding: 5px;">头像</th>
      <th style="border: 1px solid #000; padding: 5px;">操作</th>
    </tr>
    <% @authors.each do |author| %>
      <tr>
        <td style="border: 1px solid #000; padding: 5px;"><%= author.name %></td>
        <td style="border: 1px solid #000; padding: 5px;"><%= author.gender %></td>
        <td style="border: 1px solid #000; padding: 5px;"><%= author.age %></td>
        <td style="border: 1px solid #000; padding: 5px;"><%= author.description %></td>
        <td style="border: 1px solid #000; padding: 5px;"><%= author.id_number %></td>
        <td style="border: 1px solid #000; padding: 5px;">
          <% if author.avatar.present? %>
            <%= image_tag author.avatar.url, width: 100, height: 100, style: "object-fit: cover; border-radius: 8px;" %>
          <% else %>
            <p>暂无头像</p>
          <% end %>
        </td>
        <td style="border: 1px solid #000; padding: 5px;">
          <%= button_to '删除', author_path(author), method: :delete, data: { confirm: '你确定要删除这个作者吗？' } %>
          <%= link_to '修改', edit_author_path(author), class: 'btn btn-primary' %>
        </td>
      </tr>
    <% end %>
  </table>
<% else %>
  <p>暂无作者数据。</p>
<% end %>

<%= paginate @authors %>
<%= link_to '添加作者', new_author_path %>
<%= link_to '返回', books_path %>

